---
interface Props {
	title: string;
}

const { title } = Astro.props;
import '../styles/global.css'; 
---

<!doctype html>
<html lang="pl" class="scroll-smooth">
		<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;0,700;1,300;1,400&family=Montserrat:ital,wght@0,100..900;1,100..900&display=swap" rel="stylesheet">

		<!-- TUTAJ WKLEJASZ SKOPIOWANY KOD OD CLOUDFLARE, BĘDZIE WYGLĄDAŁ PODOBNIE DO TEGO: -->
		<!-- Cloudflare Web Analytics --><script defer src='https://static.cloudflareinsights.com/beacon.min.js' data-cf-beacon='{"token": "8ddc45d9ccca42148a4b37166388d4dc"}'></script><!-- End Cloudflare Web Analytics -->

		<!-- Widget logowania Netlify Identity -->
		<script src="https://identity.netlify.com/v1/netlify-identity-widget.js"></script>
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content="Studio Kokowka - Profesjonalna stylizacja fryzur ślubnych i okolicznościowych we Wrocławiu." />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>

		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;0,700;1,300;1,400&family=Montserrat:ital,wght@0,100..900;1,100..900&display=swap" rel="stylesheet">

		<!-- Skrypt natychmiastowego przekierowania tokenu aktywacyjnego do podstrony /admin/ -->
		<script is:inline>
			if (window.location.hash && (
				window.location.hash.indexOf('invite_token=') !== -1 || 
				window.location.hash.indexOf('recovery_token=') !== -1 || 
				window.location.hash.indexOf('confirmation_token=') !== -1
			)) {
				window.location.href = '/admin/' + window.location.hash;
			}
		</script>

		<!-- Widget logowania Netlify Identity -->
		<script src="https://identity.netlify.com/v1/netlify-identity-widget.js"></script>
	</head>
	<body class="bg-kokowka-pink-light text-kokowka-burgundy-dark font-sans antialiased">
		<slot />

		<!-- Skrypt logowania -->
		<script is:inline>
			if (window.netlifyIdentity) {
				window.netlifyIdentity.on("init", (user) => {
					if (!user) {
						window.netlifyIdentity.on("login", () => {
							document.location.href = "/admin/";
						});
					}
				});
			}
		</script>
	</body>
</html>