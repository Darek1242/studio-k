---
import Layout from '../layouts/Layout.astro';
import { Image } from 'astro:assets';

// Import domyślnych obrazów i logo
import heroImg1 from '../assets/hero-fryzura-1.jpg';
import heroImg2 from '../assets/hero-fryzura-2.jpg';
import heroImg3 from '../assets/hero-fryzura-3.jpg';
import logoImg from '../assets/logo.svg'; 

// Import zablokowanych dat z grafiku
import blockedDatesData from '../data/blocked-dates.json';
const blockedDates = blockedDatesData.blocked_dates || [];

// DYNAMICZNE POBIERANIE WPISÓW Z CMS (Zgodne z Astro v6 i Vite)
const cmsItems = import.meta.glob('../content/portfolio/*.md', { eager: true });
const portfolioItems = Object.values(cmsItems).reverse();
---

<Layout title="Studio Kokowka - Fryzury Ślubne i Okolicznościowe Wrocław">
  
  <!-- Nagłówek (Header) -->
  <header class="sticky top-0 z-50 bg-white/95 backdrop-blur-md border-b border-kokowka-pink-pastel/20">
    <div class="max-w-7xl mx-auto px-6 h-24 flex items-center justify-between">
      
      <a href="#home" class="block h-16 md:h-20 py-1 transition-opacity duration-300 hover:opacity-85">
        <Image 
          src={logoImg} 
          alt="Studio Kokówka" 
          class="h-full w-auto object-contain"
        />
      </a>

      <nav class="hidden md:flex items-center gap-8 font-sans text-xs tracking-[0.2em] uppercase text-kokowka-burgundy-dark/80">
        <a href="#home" class="hover:text-kokowka-burgundy transition-colors">Start</a>
        <a href="#o-mnie" class="hover:text-kokowka-burgundy transition-colors">O mnie</a>
        <a href="#portfolio" class="hover:text-kokowka-burgundy transition-colors">Portfolio</a>
        <a href="#cennik" class="hover:text-kokowka-burgundy transition-colors">Cennik</a>
        <a href="#przed-wizyta" class="hover:text-kokowka-burgundy transition-colors">Przed wizytą</a>
        <a href="#kontakt" class="inline-block bg-kokowka-burgundy-dark text-kokowka-pink-light px-6 py-3 rounded-full text-[10px] tracking-widest hover:bg-kokowka-burgundy transition-colors duration-300 shadow-sm">
          Rezerwacja
        </a>
      </nav>
    </div>
  </header>

  <!-- Sekcja Hero -->
  <section id="home" class="relative min-h-[calc(100vh-6rem)] flex items-center bg-kokowka-pink-light overflow-hidden">
    <div class="max-w-7xl mx-auto px-6 py-12 w-full grid grid-cols-1 md:grid-cols-2 gap-12 items-center">
      
      <div class="space-y-6">
        <div class="flex items-center gap-2">
          <span class="text-kokowka-burgundy text-xs">✦</span>
          <span class="font-sans text-xs tracking-[0.25em] uppercase text-kokowka-burgundy font-medium">
            Stylizacja Fryzur ✦ Wrocław 
          </span>
        </div>
        
        <h1 class="font-serif text-5xl sm:text-6xl lg:text-7xl text-kokowka-burgundy-dark leading-[1.05] tracking-wide font-light">
          Fryzury z klasą, <br />
          <span class="italic text-kokowka-burgundy">tworzone z pasją</span>
        </h1>
        
        <p class="font-sans text-kokowka-burgundy-dark/80 max-w-md text-sm sm:text-base font-light leading-relaxed tracking-wide">
          Wyjątkowe upięcia ślubne i okolicznościowe, które podkreślą Twoje naturalne piękno w najważniejszych momentach życia.
        </p>
        
        <div class="pt-4">
          <a href="#kontakt" class="inline-block bg-kokowka-burgundy-dark text-kokowka-pink-light px-8 py-4 rounded-full font-sans text-xs tracking-[0.2em] uppercase hover:bg-kokowka-burgundy transition-colors duration-300 shadow-md">
            Zapytaj o termin
          </a>
        </div>
      </div>

      <div class="relative flex justify-center items-center h-[450px] md:h-[550px] group">
        
        <div class="absolute inset-0 bg-kokowka-parchment rounded-3xl -rotate-2 transform scale-95 border border-kokowka-pink-pastel/20"></div>
        
        <div class="absolute w-[65%] h-[80%] rounded-2xl shadow-xl left-4 top-4 overflow-hidden border border-kokowka-pink-light/80 cursor-pointer
                    z-10 hover:z-30 
                    transition-all duration-700 ease-[cubic-bezier(0.16,1,0.3,1)]
                    group-hover:opacity-65 group-hover:scale-[0.96]
                    hover:!opacity-100 hover:!scale-[1.04] hover:-translate-x-3 hover:-translate-y-3 hover:shadow-2xl">
          <Image 
            src={heroImg1} 
            alt="Elegancka fryzura ślubna wykonana w Studio Kokowka" 
            widths={[240, 540, 720]}
            sizes="(max-width: 768px) 60vw, 30vw"
            loading="eager"
            fetchpriority="high"
            class="w-full h-full object-cover"
          />
        </div>
        
        <div class="absolute w-[65%] h-[80%] rounded-2xl shadow-2xl right-4 bottom-4 overflow-hidden border border-kokowka-pink-light/80 cursor-pointer
                    z-20 hover:z-30 
                    transition-all duration-700 ease-[cubic-bezier(0.16,1,0.3,1)]
                    group-hover:opacity-65 group-hover:scale-[0.96]
                    hover:!opacity-100 hover:!scale-[1.04] hover:translate-x-3 hover:translate-y-3 hover:shadow-2xl">
          <Image 
            src={heroImg2} 
            alt="Upięcie okolicznościowe o nowoczesnej, lekkiej strukturze" 
            widths={[240, 540, 720]}
            sizes="(max-width: 768px) 60vw, 30vw"
            class="w-full h-full object-cover"
          />
        </div>

      </div>
    </div>
  </section>

  <!-- SEKCJA: O MNIE -->
  <section id="o-mnie" class="py-24 bg-kokowka-parchment border-y border-kokowka-pink-pastel/20">
    <div class="max-w-7xl mx-auto px-6 grid grid-cols-1 md:grid-cols-12 gap-12 items-center">
      
      <div class="md:col-span-5 relative flex justify-center">
        <div class="absolute -inset-2 bg-kokowka-pink-pastel/30 rounded-3xl rotate-2"></div>
        <div class="relative w-full max-w-[360px] aspect-[3/4] rounded-2xl overflow-hidden shadow-lg border border-white">
          <Image 
            src={heroImg3} 
            alt="Profesjonalna stylizacja fryzury w Studio Kokówka" 
            widths={[320, 540]}
            sizes="(max-width: 768px) 80vw, 30vw"
            class="w-full h-full object-cover"
          />
        </div>
      </div>

      <div class="md:col-span-7 space-y-6">
        <div class="flex items-center gap-2">
          <span class="text-kokowka-burgundy text-xs">✦</span>
          <span class="font-sans text-xs tracking-[0.25em] uppercase text-kokowka-burgundy font-medium">Poznaj nas bliżej</span>
        </div>
        
        <h2 class="font-serif text-4xl sm:text-5xl text-kokowka-burgundy-dark font-light leading-tight">
          Poznaj <span class="italic text-kokowka-burgundy">Studio Kokówka</span>
        </h2>
        
        <div class="space-y-4 font-sans text-sm sm:text-base text-kokowka-burgundy-dark/85 font-light leading-relaxed">
          <p>
            Studio Kokówka powstało z miłości do detali i naturalnego piękna. Specjalizujemy się w tworzeniu lekkich, pełnych objętości, a zarazem niezwykle trwałych upięć ślubnych oraz fryzur okolicznościowych. 
          </p>
          <p>
            W pracy z naszymi klientkami stawiamy na pełne empatii, indywidualne podejście. Wierzymy, że idealna fryzura to taka, która nie tylko przetrwa całą noc pełną tańca, ale przede wszystkim sprawi, że poczujesz się pewną siebie, najpiękniejszą wersją samej siebie.
          </p>
          <p>
            Oferujemy ekskluzywne usługi w pełni mobilne na terenie Wrocławia i okolic. Tworzymy fryzury w wybranym przez Ciebie miejscu – w domowym zaciszu, pokoju hotelowym czy bezpośrednio w miejscu przygotowań ślubnych, dbając o Twój maksymalny komfort w spokojnej i przyjaznej atmosferze.
          </p>
        </div>

        <div class="pt-4">
          <a href="#kontakt" class="inline-block border border-kokowka-burgundy text-kokowka-burgundy px-6 py-3 rounded-full text-xs tracking-widest uppercase hover:bg-kokowka-burgundy hover:text-white transition-colors duration-300">
            Dowiedz się więcej o rezerwacjach
          </a>
        </div>
      </div>

    </div>
  </section>

  <!-- SEKCJA: PORTFOLIO -->
  <section id="portfolio" class="py-24 bg-kokowka-pink-light">
    <div class="max-w-7xl mx-auto px-6 space-y-12">
      
      <div class="text-center space-y-4 max-w-2xl mx-auto">
        <div class="flex items-center justify-center gap-2">
          <span class="text-kokowka-burgundy text-xs">✦</span>
          <span class="font-sans text-xs tracking-[0.25em] uppercase text-kokowka-burgundy font-medium">Nasze realizacje</span>
          <span class="text-kokowka-burgundy text-xs">✦</span>
        </div>
        <h2 class="font-serif text-4xl sm:text-5xl text-kokowka-burgundy-dark font-light">
          Zobacz najnowsze <span class="italic text-kokowka-burgundy">stylizacje</span>
        </h2>
        <p class="font-sans text-xs sm:text-sm text-kokowka-burgundy-dark/75 font-light tracking-wide">
          Bądź na bieżąco i zobacz, jakie upięcia królują w tym sezonie. Wszystkie zdjęcia pochodzą z mojego aktywnego portfolio na Instagramie.
        </p>
      </div>

      <!-- Jeśli w CMS nie ma jeszcze zdjęć, pokazujemy domyślne 3 zdjęcia na start -->
      {portfolioItems.length === 0 ? (
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8">
          <a href="https://www.instagram.com/studio_kokowka" target="_blank" rel="noopener noreferrer" class="group relative block aspect-[3/4] rounded-2xl overflow-hidden shadow-md border border-white/40">
            <Image src={heroImg1} alt="Upięcie ślubne Studio Kokówka" widths={[320, 480]} sizes="(max-width: 768px) 100vw, 33vw" class="w-full h-full object-cover transition-transform duration-700 ease-out group-hover:scale-105" />
          </a>
          <a href="https://www.instagram.com/studio_kokowka" target="_blank" rel="noopener noreferrer" class="group relative block aspect-[3/4] rounded-2xl overflow-hidden shadow-md border border-white/40">
            <Image src={heroImg2} alt="Fryzura ślubna Studio Kokówka" widths={[320, 480]} sizes="(max-width: 768px) 100vw, 33vw" class="w-full h-full object-cover transition-transform duration-700 ease-out group-hover:scale-105" />
          </a>
          <a href="https://www.instagram.com/studio_kokowka" target="_blank" rel="noopener noreferrer" class="group relative block aspect-[3/4] rounded-2xl overflow-hidden shadow-md border border-white/40 w-full sm:col-span-2 sm:justify-self-center sm:max-w-[calc((100%-2rem)/2)] lg:col-span-1 lg:max-w-none">
            <Image src={heroImg3} alt="Upięcie ślubne i okolicznościowe" widths={[320, 480]} sizes="(max-width: 768px) 100vw, 33vw" class="w-full h-full object-cover transition-transform duration-700 ease-out group-hover:scale-105" />
          </a>
        </div>
      ) : (
        /* Dynamiczny Grid ładowany z panelu CMS */
        ) : (
        <!-- DYNAMICZNY GRID ŁADOWANY Z PANELU CMS (Z inteligentnym wyśrodkowaniem 3. zdjęcia na tabletach) -->
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8">
          {portfolioItems.map((item, index) => {
            // Warunek: Sprawdź, czy mamy dokładnie 3 zdjęcia i czy to jest 3. zdjęcie na liście
            const isThirdOfThree = portfolioItems.length === 3 && index === 2;
            
            return (
              <a 
                href={item.frontmatter.instagram_url} 
                target="_blank" 
                rel="noopener noreferrer" 
                class={`group relative block aspect-[3/4] rounded-2xl overflow-hidden shadow-md border border-white/40 w-full
                  ${isThirdOfThree ? 'sm:col-span-2 sm:justify-self-center sm:max-w-[calc((100%-2rem)/2)] lg:col-span-1 lg:max-w-none' : ''}`}
              >
                <img 
                  src={item.frontmatter.image} 
                  alt={item.frontmatter.title} 
                  class="w-full h-full object-cover transition-transform duration-700 ease-out group-hover:scale-105" 
                  loading="lazy"
                />
                <div class="absolute inset-0 bg-kokowka-burgundy-dark/30 opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex items-center justify-center">
                  <span class="bg-white/95 text-kokowka-burgundy-dark text-xs tracking-widest uppercase px-5 py-3 rounded-full font-sans shadow-md transform translate-y-2 group-hover:translate-y-0 transition-transform duration-300">
                    {item.frontmatter.title || 'Zobacz na Instagramie ✦'}
                  </span>
                </div>
              </a>
            );
          })}
        </div>
      )}

      <div class="text-center pt-6">
        <a href="https://www.instagram.com/studio_kokowka" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-3 bg-kokowka-burgundy-dark text-kokowka-pink-light px-8 py-4 rounded-full font-sans text-xs tracking-[0.2em] uppercase hover:bg-kokowka-burgundy transition-colors duration-300 shadow-sm">
          Zaobserwuj @studio_kokowka
        </a>
      </div>

    </div>
  </section>

  <!-- SEKCJA: CENNIK -->
  <section id="cennik" class="py-24 bg-kokowka-parchment border-y border-kokowka-pink-pastel/20">
    <div class="max-w-4xl mx-auto px-6 space-y-12">
      
      <!-- Nagłówek sekcji -->
      <div class="text-center space-y-4 max-w-2xl mx-auto">
        <div class="flex items-center justify-center gap-2">
          <span class="text-kokowka-burgundy text-xs">✦</span>
          <span class="font-sans text-xs tracking-[0.25em] uppercase text-kokowka-burgundy font-medium">Proste i jasne zasady</span>
          <span class="text-kokowka-burgundy text-xs">✦</span>
        </div>
        <h2 class="font-serif text-4xl sm:text-5xl text-kokowka-burgundy-dark font-light">
          Cennik <span class="italic text-kokowka-burgundy">2026</span>
        </h2>
      </div>

      <!-- Karta cennika naśladująca Twoje zdjęcie -->
      <div class="bg-white/60 backdrop-blur-sm p-8 md:p-12 rounded-3xl border border-white/80 shadow-sm space-y-10 max-w-xl mx-auto">
        
        <!-- Pozycje cennika -->
        <div class="space-y-6 font-sans text-sm sm:text-base uppercase tracking-wider text-kokowka-burgundy-dark font-medium">
          
          <div class="flex justify-between items-baseline gap-4 border-b border-kokowka-pink-pastel/20 pb-4">
            <span>Fryzura Ślubna</span>
            <span class="font-serif text-lg font-light text-kokowka-burgundy whitespace-nowrap">200 PLN</span>
          </div>
          
          <div class="flex justify-between items-baseline gap-4 border-b border-kokowka-pink-pastel/20 pb-4">
            <span>Fryzura Próbna</span>
            <span class="font-serif text-lg font-light text-kokowka-burgundy whitespace-nowrap">200 PLN</span>
          </div>
          
          <div class="flex justify-between items-baseline gap-4 border-b border-kokowka-pink-pastel/20 pb-4">
            <span>Fryzura Okolicznościowa</span>
            <span class="font-serif text-lg font-light text-kokowka-burgundy whitespace-nowrap">200 PLN</span>
          </div>
          
          <div class="flex justify-between items-baseline gap-4">
            <span>Fryzura na Sesję Zdjęciową</span>
            <span class="font-serif text-lg font-light text-kokowka-burgundy whitespace-nowrap">200 PLN</span>
          </div>

        </div>

        <!-- Opisy i notatki z Twojego zdjęcia -->
        <div class="space-y-6 pt-6 border-t border-kokowka-pink-pastel/30 text-center font-sans">
          
          <p class="text-[11px] text-kokowka-burgundy/80 tracking-wide leading-relaxed uppercase max-w-sm mx-auto font-light">
            *Podczas sesji zdjęciowej zostaję do końca i zapewniam poprawki podczas jej trwania
          </p>

          <div class="space-y-1 text-xs text-kokowka-burgundy-dark/90 tracking-wide uppercase font-light">
            <p>Dojazd na terenie Wrocławia gratis</p>
            <p>Poza Wrocławiem 2 zł/km liczony w obie strony</p>
          </div>

          <div class="pt-4 text-[10px] tracking-[0.25em] text-kokowka-burgundy uppercase font-semibold">
            Więcej informacji w wiadomości prywatnej (DM)
          </div>

        </div>

      </div>

    </div>
  </section>

  <!-- SEKCJA: PRZED WIZYTĄ -->
  <section id="przed-wizyta" class="py-24 bg-kokowka-pink-light">
    <div class="max-w-7xl mx-auto px-6 space-y-16">
      
      <!-- Nagłówek sekcji z obustronnymi gwiazdkami -->
      <div class="text-center space-y-4 max-w-2xl mx-auto">
        <div class="flex items-center justify-center gap-2">
          <span class="text-kokowka-burgundy text-xs">✦</span>
          <span class="font-sans text-xs tracking-[0.25em] uppercase text-kokowka-burgundy font-medium">Jak się przygotować</span>
          <span class="text-kokowka-burgundy text-xs">✦</span>
        </div>
        <h2 class="font-serif text-4xl sm:text-5xl text-kokowka-burgundy-dark font-light uppercase tracking-wide">
          Przed <span class="italic text-kokowka-burgundy">Wizytą</span>
        </h2>
      </div>

      <!-- Trzykolumnowy układ (Pielęgnacja, Stylizacja, Ubiór) -->
      <div class="grid grid-cols-1 md:grid-cols-3 gap-12 items-start">
        
        <!-- Kategoria 1: Pielęgnacja -->
        <div class="bg-white/40 backdrop-blur-sm p-8 rounded-3xl border border-white/60 shadow-sm space-y-6">
          <div class="border-b border-kokowka-pink-pastel/30 pb-3">
            <h3 class="font-serif text-xl tracking-wider text-kokowka-burgundy uppercase font-light">Pielęgnacja</h3>
          </div>
          <ul class="space-y-4 font-sans text-xs sm:text-sm text-kokowka-burgundy-dark/90 font-light leading-relaxed uppercase tracking-wider">
            <li class="flex items-start gap-3">
              <span class="text-kokowka-burgundy text-[10px] mt-1 shrink-0">✦</span>
              <span>Umyj włosy dzień wcześniej wieczorem lub rano, minimum 3 godziny przed stylizacją</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="text-kokowka-burgundy text-[10px] mt-1 shrink-0">✦</span>
              <span>Umyj włosy dwukrotnie szamponem; możesz zastosować delikatną odżywkę</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="text-kokowka-burgundy text-[10px] mt-1 shrink-0">✦</span>
              <span>Dokładnie wysusz włosy</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="text-kokowka-burgundy text-[10px] mt-1 shrink-0">✦</span>
              <span>Nie nakładaj olejków ani serum</span>
            </li>
          </ul>
        </div>

        <!-- Kategoria 2: Stylizacja -->
        <div class="bg-white/40 backdrop-blur-sm p-8 rounded-3xl border border-white/60 shadow-sm space-y-6">
          <div class="border-b border-kokowka-pink-pastel/30 pb-3">
            <h3 class="font-serif text-xl tracking-wider text-kokowka-burgundy uppercase font-light">Stylizacja</h3>
          </div>
          <ul class="space-y-4 font-sans text-xs sm:text-sm text-kokowka-burgundy-dark/90 font-light leading-relaxed uppercase tracking-wider">
            <li class="flex items-start gap-3">
              <span class="text-kokowka-burgundy text-[10px] mt-1 shrink-0">✦</span>
              <span>Nie stylizuj włosów prostownicą, lokówką ani innymi urządzeniami termicznymi</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="text-kokowka-burgundy text-[10px] mt-1 shrink-0">✦</span>
              <span>Jeśli fryzura ma bazować na Twoim naturalnym skręcie, wydobądź go wcześniej w domu</span>
            </li>
          </ul>
        </div>

        <!-- Kategoria 3: Ubiór -->
        <div class="bg-white/40 backdrop-blur-sm p-8 rounded-3xl border border-white/60 shadow-sm space-y-6">
          <div class="border-b border-kokowka-pink-pastel/30 pb-3">
            <h3 class="font-serif text-xl tracking-wider text-kokowka-burgundy uppercase font-light">Ubiór</h3>
          </div>
          <ul class="space-y-4 font-sans text-xs sm:text-sm text-kokowka-burgundy-dark/90 font-light leading-relaxed uppercase tracking-wider">
            <li class="flex items-start gap-3">
              <span class="text-kokowka-burgundy text-[10px] mt-1 shrink-0">✦</span>
              <span>Wybierz ubranie, które można łatwo zdjąć bez naruszania fryzury</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="text-kokowka-burgundy text-[10px] mt-1 shrink-0">✦</span>
              <span>Na fryzurę próbną wybierz jasną/białą bluzkę</span>
            </li>
          </ul>
        </div>

      </div>

    </div>
  </section>

  <!-- SEKCJA: INTERAKTYWNA REZERWACJA -->
  <section id="kontakt" class="py-24 bg-kokowka-parchment border-t border-kokowka-pink-pastel/20">
    <div class="max-w-3xl mx-auto px-6 space-y-12">
      
      <!-- Nagłówek sekcji z obustronnymi gwiazdkami -->
      <div class="text-center space-y-4 max-w-2xl mx-auto">
        <div class="flex items-center justify-center gap-2">
          <span class="text-kokowka-burgundy text-xs">✦</span>
          <span class="font-sans text-xs tracking-[0.25em] uppercase text-kokowka-burgundy font-medium">Zarezerwuj swój termin</span>
          <span class="text-kokowka-burgundy text-xs">✦</span>
        </div>
        <h2 class="font-serif text-4xl sm:text-5xl text-kokowka-burgundy-dark font-light">
          Zapytaj o <span class="italic text-kokowka-burgundy">rezerwację</span>
        </h2>
        <p class="font-sans text-xs sm:text-sm text-kokowka-burgundy-dark/75 font-light tracking-wide">
          Wypełnij krótki formularz, abyśmy mogły idealnie zaplanować Twój wyjątkowy dzień. Wycena zaktualizuje się automatycznie.
        </p>
      </div>

      <div class="bg-white p-8 md:p-12 rounded-3xl border border-kokowka-pink-pastel/30 shadow-sm space-y-8">
        
        <!-- Komunikat o sukcesie (Domyślnie ukryty) -->
        <div id="success-message" class="hidden bg-emerald-50 border border-emerald-200 p-8 rounded-3xl text-center space-y-4">
          <span class="text-emerald-600 text-3xl">✦</span>
          <h3 class="font-serif text-2xl text-emerald-900 font-light">Wiadomość została wysłana!</h3>
          <p class="font-sans text-sm text-emerald-800/80 max-w-md mx-auto">
            Dziękujemy za przesłanie zgłoszenia. Dokładnie zapoznamy się z Twoimi wymaganiami i skontaktujemy się z Tobą w celu potwierdzenia terminu.
          </p>
        </div>

        <!-- Wizualny wskaźnik postępu (Progress steps) -->
        <div id="progress-container" class="relative">
          <div class="absolute top-1/2 left-0 w-full h-[2px] bg-stone-100 -translate-y-1/2 z-0"></div>
          <div id="progress-bar" class="absolute top-1/2 left-0 w-0 h-[2px] bg-kokowka-burgundy -translate-y-1/2 z-0 transition-all duration-500 ease-out"></div>
          
          <div class="relative z-10 flex justify-between">
            <div data-progress-step="1" class="bg-white px-3 text-[10px] tracking-widest uppercase text-kokowka-burgundy font-semibold">1. Wydarzenie</div>
            <div data-progress-step="2" class="bg-white px-3 text-[10px] tracking-widest uppercase text-kokowka-burgundy-dark/40 transition-colors duration-300">2. Włosy</div>
            <div data-progress-step="3" class="bg-white px-3 text-[10px] tracking-widest uppercase text-kokowka-burgundy-dark/40 transition-colors duration-300">3. Logistyka</div>
          </div>
        </div>

        <!-- Formularz -->
        <form id="booking-form" class="space-y-6" name="kontakt" method="POST" data-netlify="true">
          <input type="hidden" name="form-name" value="kontakt" />
          
          <!-- KROK 1: Wydarzenie -->
          <div data-form-step="1" class="space-y-6">
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
              <div class="space-y-2">
                <label for="event-date" class="block font-sans text-xs tracking-wider uppercase text-kokowka-burgundy-dark/80">Data wydarzenia *</label>
                <input 
                  required 
                  type="date" 
                  id="event-date" 
                  name="data-wydarzenia" 
                  data-blocked-dates={JSON.stringify(blockedDates)}
                  class="w-full bg-kokowka-pink-light/30 border border-kokowka-pink-pastel/45 rounded-xl px-4 py-3 text-sm text-kokowka-burgundy-dark focus:outline-none focus:border-kokowka-burgundy focus:ring-1 focus:ring-kokowka-burgundy transition-all" 
                />
                <!-- Komunikat o zajętej dacie -->
                <div id="date-warning-message" class="hidden text-[11px] text-kokowka-burgundy mt-2 font-medium tracking-wide leading-relaxed">
                  ✦ Ten termin jest już zajęty. Napisz do mnie na Instagramie (DM) lub napisz na studio.kokowka@gmail.com, aby zapytać o wolne godziny! ✦
                </div>
              </div>
              <div class="space-y-2">
                <label for="event-type" class="block font-sans text-xs tracking-wider uppercase text-kokowka-burgundy-dark/80">Rodzaj stylizacji *</label>
                <select required id="event-type" name="rodzaj-stylizacji" class="w-full bg-kokowka-pink-light/30 border border-kokowka-pink-pastel/45 rounded-xl px-4 py-3 text-sm text-kokowka-burgundy-dark focus:outline-none focus:border-kokowka-burgundy focus:ring-1 focus:ring-kokowka-burgundy transition-all">
                  <option value="Fryzura Ślubna">Fryzura Ślubna</option>
                  <option value="Fryzura Próbna">Fryzura Próbna</option>
                  <option value="Fryzura Okolicznościowa">Fryzura Okolicznościowa (Gość)</option>
                  <option value="Stylizacja do sesji zdjęciowej">Stylizacja do sesji zdjęciowej</option>
                </select>
              </div>
            </div>
            
            <div class="flex justify-end pt-4">
              <button type="button" data-next-step class="bg-kokowka-burgundy-dark text-kokowka-pink-light px-8 py-3.5 rounded-full font-sans text-xs tracking-widest uppercase hover:bg-kokowka-burgundy transition-colors duration-300 shadow-sm cursor-pointer">
                Dalej ✦
              </button>
            </div>
          </div>

          <!-- KROK 2: Włosy -->
          <div data-form-step="2" class="space-y-6 hidden">
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
              
              <div class="space-y-2">
                <label for="hair-length" class="block font-sans text-xs tracking-wider uppercase text-kokowka-burgundy-dark/80">Długość włosów *</label>
                <select id="hair-length" name="dlugosc-wlosow" class="w-full bg-kokowka-pink-light/30 border border-kokowka-pink-pastel/45 rounded-xl px-4 py-3 text-sm text-kokowka-burgundy-dark focus:outline-none focus:border-kokowka-burgundy focus:ring-1 focus:ring-kokowka-burgundy transition-all">
                  <option value="Krótkie (do ramion)">Krótkie (do ramion)</option>
                  <option value="Średnie (do łopatek)">Średnie (do łopatek)</option>
                  <option value="Długie (ponad łopatki)">Długie (ponad łopatki)</option>
                </select>
              </div>

              <div class="space-y-2">
                <label for="hair-density" class="block font-sans text-xs tracking-wider uppercase text-kokowka-burgundy-dark/80">Gęstość włosów *</label>
                <select id="hair-density" name="gestosc-wlosow" class="w-full bg-kokowka-pink-light/30 border border-kokowka-pink-pastel/45 rounded-xl px-4 py-3 text-sm text-kokowka-burgundy-dark focus:outline-none focus:border-kokowka-burgundy focus:ring-1 focus:ring-kokowka-burgundy transition-all">
                  <option value="Rzadkie / Delikatne">Rzadkie / Delikatne</option>
                  <option value="Normalne / Standardowe">Normalne / Standardowe</option>
                  <option value="Gęste / Grube">Gęste / Grube</option>
                </select>
              </div>

            </div>

            <div class="space-y-2">
              <label for="hair-history" class="block font-sans text-xs tracking-wider uppercase text-kokowka-burgundy-dark/80">Dodatkowe informacje o włosach (opcjonalnie)</label>
              <textarea id="hair-history" name="dodatkowe-informacje" rows="3" placeholder="np. włosy rozjaśniane, przedłużane, bardzo śliskie, podatne na kręcenie..." class="w-full bg-kokowka-pink-light/30 border border-kokowka-pink-pastel/45 rounded-xl px-4 py-3 text-sm text-kokowka-burgundy-dark placeholder-kokowka-burgundy-dark/40 focus:outline-none focus:border-kokowka-burgundy focus:ring-1 focus:ring-kokowka-burgundy transition-all"></textarea>
            </div>

            <div class="flex justify-between pt-4">
              <button type="button" data-prev-step class="border border-kokowka-burgundy text-kokowka-burgundy px-8 py-3.5 rounded-full font-sans text-xs tracking-widest uppercase hover:bg-kokowka-burgundy hover:text-white transition-colors duration-300 cursor-pointer">
                ✦ Wstecz
              </button>
              <button type="button" data-next-step class="bg-kokowka-burgundy-dark text-kokowka-pink-light px-8 py-3.5 rounded-full font-sans text-xs tracking-widest uppercase hover:bg-kokowka-burgundy transition-colors duration-300 shadow-sm cursor-pointer">
                Dalej ✦
              </button>
            </div>
          </div>

          <!-- KROK 3: Logistyka i kontakt -->
          <div data-form-step="3" class="space-y-6 hidden">
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
              
              <div class="space-y-2">
                <label for="ready-time" class="block font-sans text-xs tracking-wider uppercase text-kokowka-burgundy-dark/80">Godzina gotowości fryzury *</label>
                <input required type="time" id="ready-time" name="godzina-gotowosci" class="w-full bg-kokowka-pink-light/30 border border-kokowka-pink-pastel/45 rounded-xl px-4 py-3 text-sm text-kokowka-burgundy-dark focus:outline-none focus:border-kokowka-burgundy focus:ring-1 focus:ring-kokowka-burgundy transition-all" />
              </div>

              <div class="space-y-2">
                <label for="location-type" class="block font-sans text-xs tracking-wider uppercase text-kokowka-burgundy-dark/80">Miejsce stylizacji *</label>
                <select required id="location-type" name="miejsce-stylizacji" class="w-full bg-kokowka-pink-light/30 border border-kokowka-pink-pastel/45 rounded-xl px-4 py-3 text-sm text-kokowka-burgundy-dark focus:outline-none focus:border-kokowka-burgundy focus:ring-1 focus:ring-kokowka-burgundy transition-all">
                  <option value="wroclaw">Mobilnie (na terenie Wrocławia)</option>
                  <option value="poza-wroclawiem">Mobilnie (poza granicami Wrocławia)</option>
                </select>
              </div>

            </div>

            <div class="grid grid-cols-1 sm:grid-cols-3 gap-6">
              <div class="space-y-2">
                <label for="client-name" class="block font-sans text-xs tracking-wider uppercase text-kokowka-burgundy-dark/80">Imię i nazwisko *</label>
                <input required type="text" id="client-name" name="imie-i-nazwisko" placeholder="np. Anna Nowak" class="w-full bg-kokowka-pink-light/30 border border-kokowka-pink-pastel/45 rounded-xl px-4 py-3 text-sm text-kokowka-burgundy-dark focus:outline-none focus:border-kokowka-burgundy focus:ring-1 focus:ring-kokowka-burgundy transition-all" />
              </div>
              <div class="space-y-2">
                <label for="client-email" class="block font-sans text-xs tracking-wider uppercase text-kokowka-burgundy-dark/80">E-mail *</label>
                <input required type="email" id="client-email" name="email" placeholder="np. anna@gmail.com" class="w-full bg-kokowka-pink-light/30 border border-kokowka-pink-pastel/45 rounded-xl px-4 py-3 text-sm text-kokowka-burgundy-dark focus:outline-none focus:border-kokowka-burgundy focus:ring-1 focus:ring-kokowka-burgundy transition-all" />
              </div>
              <div class="space-y-2">
                <label for="client-phone" class="block font-sans text-xs tracking-wider uppercase text-kokowka-burgundy-dark/80">Telefon *</label>
                <input required type="tel" id="client-phone" name="telefon" placeholder="np. 500 600 700" class="w-full bg-kokowka-pink-light/30 border border-kokowka-pink-pastel/45 rounded-xl px-4 py-3 text-sm text-kokowka-burgundy-dark focus:outline-none focus:border-kokowka-burgundy focus:ring-1 focus:ring-kokowka-burgundy transition-all" />
              </div>
            </div>

            <!-- Panel podsumowania ceny -->
            <div class="bg-kokowka-parchment p-6 rounded-2xl border border-kokowka-pink-pastel/30 flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4 mt-6">
              <div>
                <h4 class="font-sans text-xs tracking-wider uppercase text-kokowka-burgundy font-semibold">Szacowany koszt usługi:</h4>
                <p id="price-details" class="font-sans text-[11px] text-kokowka-burgundy-dark/70 font-light mt-1">
                  (W tym dojazd na terenie Wrocławia: Gratis)
                </p>
              </div>
              <div class="flex items-baseline gap-2">
                <span id="calculated-price" class="font-serif text-3xl text-kokowka-burgundy font-semibold">200 zł</span>
              </div>
            </div>

            <div class="flex justify-between pt-4">
              <button type="button" data-prev-step class="border border-kokowka-burgundy text-kokowka-burgundy px-8 py-3.5 rounded-full font-sans text-xs tracking-widest uppercase hover:bg-kokowka-burgundy hover:text-white transition-colors duration-300 cursor-pointer">
                ✦ Wstecz
              </button>
              <button type="submit" class="bg-kokowka-burgundy-dark text-kokowka-pink-light px-10 py-3.5 rounded-full font-sans text-xs tracking-widest uppercase hover:bg-kokowka-burgundy transition-colors duration-300 shadow-md cursor-pointer font-semibold">
                Wyślij zapytanie ✦
              </button>
            </div>
          </div>

        </form>

      </div>

    </div>
  </section>

</Layout>

<!-- SKRYPT JS -->
<script>
  const steps = document.querySelectorAll('[data-form-step]');
  const nextBtns = document.querySelectorAll('[data-next-step]');
  const prevBtns = document.querySelectorAll('[data-prev-step]');
  const progressBar = document.getElementById('progress-bar');
  const progressSteps = document.querySelectorAll('[data-progress-step]');
  
  const locationSelect = document.getElementById('location-type');
  const priceDisplay = document.getElementById('calculated-price');
  const priceDetails = document.getElementById('price-details');

  const form = document.getElementById('booking-form');
  const successMessage = document.getElementById('success-message');
  const progressContainer = document.getElementById('progress-container');

  const eventDateInput = document.getElementById('event-date');
  const dateWarning = document.getElementById('date-warning-message');
  const step1NextBtn = document.querySelector('[data-form-step="1"] [data-next-step]');

  let currentStep = 1;

  function updateForm() {
    steps.forEach(step => {
      const stepNum = parseInt(step.getAttribute('data-form-step') || '0', 10);
      if (stepNum === currentStep) {
        step.classList.remove('hidden');
      } else {
        step.classList.add('hidden');
      }
    });

    if (progressBar) {
      const percentage = ((currentStep - 1) / (steps.length - 1)) * 100;
      progressBar.style.width = `${percentage}%`;
    }

    progressSteps.forEach(ind => {
      const indNum = parseInt(ind.getAttribute('data-progress-step') || '0', 10);
      if (indNum <= currentStep) {
        ind.classList.add('text-kokowka-burgundy', 'font-semibold');
        ind.classList.remove('text-kokowka-burgundy-dark/40');
      } else {
        ind.classList.remove('text-kokowka-burgundy', 'font-semibold');
        ind.classList.add('text-kokowka-burgundy-dark/40');
      }
    });
  }

  if (eventDateInput instanceof HTMLInputElement) {
    const blockedList = JSON.parse(eventDateInput.getAttribute('data-blocked-dates') || '[]');

    eventDateInput.addEventListener('change', () => {
      const selected = eventDateInput.value;
      
      if (blockedList.includes(selected)) {
        if (dateWarning) dateWarning.classList.remove('hidden');
        if (step1NextBtn) {
          step1NextBtn.setAttribute('disabled', 'true');
          step1NextBtn.classList.add('opacity-50', 'cursor-not-allowed');
        }
      } else {
        if (dateWarning) dateWarning.classList.add('hidden');
        if (step1NextBtn) {
          step1NextBtn.removeAttribute('disabled');
          step1NextBtn.classList.remove('opacity-50', 'cursor-not-allowed');
        }
      }
    });
  }

  nextBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      const currentStepContainer = document.querySelector(`[data-form-step="${currentStep}"]`);
      if (currentStepContainer) {
        const requiredInputs = currentStepContainer.querySelectorAll('[required]');
        let allValid = true;
        requiredInputs.forEach(input => {
          if (input instanceof HTMLInputElement || input instanceof HTMLSelectElement) {
            if (!input.checkValidity()) {
              input.reportValidity();
              allValid = false;
            }
          }
        });
        if (!allValid) return;
      }

      if (currentStep < steps.length) {
        currentStep++;
        updateForm();
      }
    });
  });

  prevBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      if (currentStep > 1) {
        currentStep--;
        updateForm();
      }
    });
  });

  if (locationSelect instanceof HTMLSelectElement) {
    locationSelect.addEventListener('change', () => {
      const val = locationSelect.value;
      if (priceDisplay && priceDetails) {
        if (val === 'poza-wroclawiem') {
          priceDisplay.textContent = '250 zł';
          priceDetails.textContent = '(W tym dojazd poza Wrocław: 50 zł)';
        } else {
          priceDisplay.textContent = '200 zł';
          priceDetails.textContent = '(W tym dojazd na terenie Wrocławia / stacjonarnie: Gratis)';
        }
      }
    });
  }

  if (form instanceof HTMLFormElement) {
    form.addEventListener('submit', (e) => {
      e.preventDefault();

      const formData = new FormData(form);

      fetch('/', {
        method: 'POST',
        headers: { "Content-Type": "application/x-www-form-urlencoded" },
        body: new URLSearchParams(formData as any).toString()
      })
      .then(() => {
        form.classList.add('hidden');
        if (successMessage) successMessage.classList.remove('hidden');
        if (progressContainer) progressContainer.classList.add('hidden');
      })
      .catch((error) => {
        alert("Wystąpił błąd podczas wysyłania formularza. Spróbuj ponownie.");
        console.error(error);
      });
    });
  }

  updateForm();
</script>